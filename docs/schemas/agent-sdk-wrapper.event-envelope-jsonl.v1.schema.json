{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-sdk-wrapper.local/schemas/agent-sdk-wrapper.event-envelope-jsonl.v1.schema.json",
  "title": "agent-sdk-wrapper EventEnvelope JSONL v1 line",
  "description": "Schema for one line in trace.jsonl.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "sequence", "timestamp", "event"],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event": {
      "oneOf": [
        { "$ref": "#/$defs/run_started" },
        { "$ref": "#/$defs/text" },
        { "$ref": "#/$defs/thinking" },
        { "$ref": "#/$defs/tool_call" },
        { "$ref": "#/$defs/tool_result" },
        { "$ref": "#/$defs/agent_updated" },
        { "$ref": "#/$defs/usage" },
        { "$ref": "#/$defs/session_info" },
        { "$ref": "#/$defs/structured_output" },
        { "$ref": "#/$defs/warning" },
        { "$ref": "#/$defs/error" },
        { "$ref": "#/$defs/run_finished" }
      ]
    }
  },
  "$defs": {
    "json_object": {
      "type": "object",
      "additionalProperties": true
    },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "total_tokens",
        "cache_read_tokens",
        "cache_write_tokens",
        "reasoning_output_tokens",
        "requests"
      ],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "cache_read_tokens": { "type": "integer", "minimum": 0 },
        "cache_write_tokens": { "type": "integer", "minimum": 0 },
        "reasoning_output_tokens": { "type": "integer", "minimum": 0 },
        "requests": { "type": "integer", "minimum": 0 }
      }
    },
    "run_started": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "provider"],
      "properties": {
        "type": { "const": "run_started" },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "cwd": { "type": "string" }
      }
    },
    "text": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "text" },
        "text": { "type": "string" },
        "raw": { "$ref": "#/$defs/json_object" }
      }
    },
    "thinking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "thinking" },
        "text": { "type": "string" },
        "raw": { "$ref": "#/$defs/json_object" }
      }
    },
    "tool_call": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "tool_call" },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "input": { "$ref": "#/$defs/json_object" },
        "raw": { "$ref": "#/$defs/json_object" }
      }
    },
    "tool_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "is_error"],
      "properties": {
        "type": { "const": "tool_result" },
        "id": { "type": "string" },
        "output": { "type": "string" },
        "is_error": { "type": "boolean" },
        "raw": { "$ref": "#/$defs/json_object" }
      }
    },
    "agent_updated": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name"],
      "properties": {
        "type": { "const": "agent_updated" },
        "name": { "type": "string" }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "usage"],
      "properties": {
        "type": { "const": "usage" },
        "usage": { "$ref": "#/$defs/token_usage" },
        "cost_usd": { "type": "number", "minimum": 0 },
        "raw": { "$ref": "#/$defs/json_object" }
      }
    },
    "session_info": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "const": "session_info" },
        "id": { "type": "string" }
      }
    },
    "structured_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "structured_output" },
        "value": true
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "message"],
      "properties": {
        "type": { "const": "warning" },
        "message": { "type": "string" },
        "raw": { "$ref": "#/$defs/json_object" }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "message"],
      "properties": {
        "type": { "const": "error" },
        "message": { "type": "string" },
        "error_type": { "type": "string" },
        "raw": { "$ref": "#/$defs/json_object" }
      }
    },
    "run_finished": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "status", "duration_ms"],
      "properties": {
        "type": { "const": "run_finished" },
        "status": {
          "enum": ["success", "failure", "timeout", "cancelled"]
        },
        "ended_reason": {
          "enum": ["unknown", "success", "max_turns", "timeout", "refused", "error", "cancelled"]
        },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
